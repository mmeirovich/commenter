# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API key — required for CrewAI agents
OPENAI_API_KEY=sk-...

# Serper.dev API key — required for web search in the researcher agent
# Get one at https://serper.dev (free tier available)
SERPER_API_KEY=...

# Model to use. gpt-4o-mini is the default (cheap & fast).
# For higher quality, try: gpt-4o
OPENAI_MODEL=gpt-4o-mini

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
